{
  "name": "@arch-analysis/db",
  "version": "0.1.0",
  "private": true,
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "tsc --noEmit",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "echo 'Generate D1 types from schema'",
    "db:migrate": "wrangler d1 migrations apply arch-analysis-db --remote",
    "db:studio": "wrangler d1 execute arch-analysis-db --command='SELECT * FROM projects' --remote"
  },
  "dependencies": {
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.2024000.0",
    "typescript": "^5.3.0",
    "wrangler": "^3.30.0",
    "vitest": "^1.2.0",
    "eslint": "^8.56.0"
  }
}
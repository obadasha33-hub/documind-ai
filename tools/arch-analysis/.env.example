# Cloudflare API Token (Account-level: Workers, KV, D1, R2, Queues, Pages)
# Get from: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token-here

# Cloudflare Account ID (from `wrangler whoami` or dashboard URL)
CLOUDFLARE_ACCOUNT_ID=your-account-id-here

# Google Gemini API Key (optional, for AI recommendations)
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# NOTE: GH_PAT (GitHub PAT for Advisory DB access, scopes: repo, read:org) is
# NOT a local .env variable. It's consumed only by
# .github/workflows/deploy.yml via `${{ secrets.GH_PAT }}` in CI. Add it in
# your GitHub repo under Settings → Secrets and variables → Actions — never
# in a file on disk.
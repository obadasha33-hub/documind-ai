# ── DocuMind AI backend configuration ──────────────────────────────
# Copy to `backend/.env` and fill in. Never commit the real .env.

# App
ENVIRONMENT=development          # set to "production" on deploy
DEBUG=true                       # MUST be false in production
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# Shared secret between the Next.js server and this API for the auth bridge.
# Generate with: openssl rand -hex 32
# REQUIRED in production. Must match the frontend's INTERNAL_AUTH_SECRET.
INTERNAL_AUTH_SECRET=

# Database (Neon Postgres or local Docker)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/documind

# Gemini (primary LLM + embeddings)
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=768

# Groq (fallback LLM)
GROQ_API_KEY=
GROQ_CHAT_MODEL=llama-3.1-8b-instant

# Cloudflare R2 (document storage; falls back to LOCAL_UPLOAD_DIR if unset)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=documind-docs
R2_ENDPOINT_URL=
LOCAL_UPLOAD_DIR=uploads

# Email (optional)
RESEND_API_KEY=
EMAIL_FROM=noreply@documind.ai

# CORS — comma/JSON list of allowed frontend origins
# CORS_ORIGINS=["http://localhost:3000"]

# Uploads
MAX_UPLOAD_SIZE_MB=10

# Auth token lifetime
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
